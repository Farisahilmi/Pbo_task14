# ================================================
# MovieTickets Platform - .gitignore
# ================================================

# ─── Credentials & Secrets (JANGAN pernah di-commit!) ───
*.jwk
*.pem
*.key
*.env
.env
.env.*
!.env.example
secret.jwk

# ─── Backend: Java / Quarkus / Maven ───
backend/target/
backend/.mvn/wrapper/maven-wrapper.jar
backend/.quarkus/
backend/data/
!backend/.mvn/wrapper/maven-wrapper.properties
*.class
*.jar
*.war
*.ear
*.nar
*.mv.db
*.trace.db
hs_err_pid*
replay_pid*

# ─── Backend: Python scripts (utility only, not needed in prod) ───
backend/*.py
backend/*.pyc
backend/__pycache__/
backend/test_output.py

# ─── Frontend: Node / Vite ───
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.cache/

# ─── Logs ───
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── IDE & Editor ───
.idea/
*.iml
*.iws
.factorypath
*.swp
*.swo
.DS_Store
Thumbs.db

# ─── Docker (runtime) ───
# docker-compose.override.yml  # uncomment jika ada overrides lokal

# ─── OS Files ───
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# Node
node_modules/
frontend/node_modules/

# Env
.env
*.env

# Java
target/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db